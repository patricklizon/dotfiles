// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
{
	"active_pane_modifiers": {
		"inactive_opacity": 0.68
	},
	"agent": {
		"always_allow_tool_actions": true,
		"default_view": "thread",
		// https://container-use.com/agent-integrations#zed
		"default_profile": "write",
		"default_model": {
			"model": "gemini-2.5-pro",
			"provider": "google"
		},
		"inline_assistant_model": {
			"model": "gemini-2.5-flash",
			"provider": "google"
		},
		"inline_alternatives": [
			{
				"provider": "google",
				"model": "gemini-2.5-pro"
			}
		],
		"profiles": {
			// https://container-use.com/agent-integrations#zed
			"container-use": {
				"name": "Container Use",
				"tools": {
					"fetch": true,
					"thinking": true,
					"copy_path": false,
					"find_path": false,
					"delete_path": false,
					"create_directory": false,
					"list_directory": false,
					"diagnostics": false,
					"read_file": false,
					"open": false,
					"move_path": false,
					"grep": false,
					"edit_file": false,
					"terminal": false
				},
				"enable_all_context_servers": false,
				"context_servers": {
					"container-use": {
						"tools": {
							"environment_add_service": true,
							"environment_checkpoint": true,
							"environment_config": true,
							"environment_create": true,
							"environment_file_delete": true,
							"environment_file_edit": true,
							"environment_file_list": true,
							"environment_file_read": true,
							"environment_file_write": true,
							"environment_open": true,
							"environment_run_cmd": true,
							"environment_update_metadata": true
						}
					}
				}
			}
		}
	},
	"context_servers": {
		"container-use": {
			"enabled": true,
			"source": "custom",
			"command": "container-use",
			"args": ["stdio"],
			"env": {}
		}
	},
	"buffer_font_family": "JetBrains Mono",
	"buffer_font_size": 13,
	"edit_predictions": {
		"mode": "subtle"
	},
	"features": {
		"edit_prediction_provider": "none"
	},
	"format_on_save": "on",
	"formatter": "auto",
	"icon_theme": "Zed (Default)",
	"project_panel": {
		"entry_spacing": "comfortable",
		"folder_icons": false
	},
	"relative_line_numbers": true,
	"scroll_beyond_last_line": "off",
	"show_whitespaces": "boundary",
	"show_wrap_guides": true,
	"soft_wrap": "editor_width",
	"tab_bar": {
		"show": true,
		"show_nav_history_buttons": false
	},
	"hard_tabs": true,
	"tab_size": 4,
	"tabs": {
		"git_status": true,
		"file_icons": true,
		"show_diagnostics": "all"
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"terminal": {
		"button": false,
		"blinking": "on",
		"cursor_shape": "bar",
		"copy_on_select": true,
		"env": {
			"EDITOR": "zed --wait"
		}
	},
	"theme": {
		"dark": "Ayu Dark",
		"light": "Ayu Mirage"
	},
	"ui_font_size": 16,
	"vim": {
		"cursor_shape": {
			"insert": "bar",
			"normal": "block",
			"replace": "underline",
			"visual": "hollow"
		},
		"use_system_clipboard": "always"
	},
	"vim_mode": true,
	"wrap_guides": [100, 120],
	"confirm_quit": true
}
